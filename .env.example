# APOS Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# AI Provider Configuration (至少配置一个)
# =============================================================================

# Anthropic Claude API Key
# 获取地址: https://console.anthropic.com/
# 推荐模型: claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API Key
# 获取地址: https://platform.openai.com/api-keys
# 推荐模型: gpt-4-turbo-preview
OPENAI_API_KEY=sk-your-key-here

# Google Generative AI API Key
# 获取地址: https://makersuite.google.com/app/apikey
# 推荐模型: gemini-1.5-pro
GOOGLE_GENERATIVE_AI_API_KEY=your-key-here

# =============================================================================
# GitHub Integration (可选)
# =============================================================================

# GitHub Personal Access Token
# 用于创建 Pull Requests 和发布代码审查评论
# 获取地址: https://github.com/settings/tokens
# 需要权限: repo (Full control of private repositories)
GITHUB_TOKEN=ghp_your-token-here

# =============================================================================
# Application Configuration
# =============================================================================

# Node Environment
# 开发环境: development
# 生产环境: production
NODE_ENV=development

# Application Port (默认 3000)
# PORT=3000

# Application Base URL (用于服务端 fetch 自身接口，默认 http://localhost:3000)
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# LM Studio Base URL (默认 http://localhost:1234)
# LMSTUDIO_BASE_URL=http://localhost:1234

# =============================================================================
# Database Configuration (使用默认值即可)
# =============================================================================

# SQLite Database Path (相对于项目根目录)
# DATABASE_PATH=./data/apos.db

# LanceDB Vector Database Path (相对于项目根目录)
# VECTORDB_PATH=./data/vectordb

# =============================================================================
# Advanced Configuration (高级配置，通常不需要修改)
# =============================================================================

# LLM Request Timeout (毫秒)
# LLM_TIMEOUT=120000

# Max Tokens for Code Generation
# MAX_TOKENS=4096

# RAG Search Top K Results
# RAG_TOP_K=3

# Self-healing Max Retries
# SELF_HEAL_MAX_RETRIES=3

# Agent Trace Polling Interval (毫秒)
# TRACE_POLLING_INTERVAL=2000

# =============================================================================
# 使用说明
# =============================================================================

# 1. 复制此文件为 .env.local:
#    cp .env.example .env.local

# 2. 至少配置一个 AI Provider 的 API Key:
#    - Anthropic (推荐): 最强大的代码生成能力
#    - OpenAI: 广泛使用，性能稳定
#    - Google: 免费额度较高

# 3. (可选) 配置 GitHub Token:
#    - 如果不配置，代码会生成但不会创建 PR
#    - 可以手动在本地合并分支

# 4. 启动应用:
#    npm run dev

# =============================================================================
# 安全提示
# =============================================================================

# ⚠️ 重要: 
# - 不要将 .env.local 提交到 Git
# - 不要在公开场合分享您的 API Keys
# - 定期轮换您的 API Keys
# - 使用环境变量管理工具（如 1Password、Vault）存储敏感信息

# .env.local 已在 .gitignore 中，不会被提交
