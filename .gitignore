# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep .env.example (it's a template, safe to commit)

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite database files (contain user data, API keys, cookies)
data/apos.db
data/apos.db-shm
data/apos.db-wal
# Vector DB (large binary files, auto-generated)
data/vectordb/
data/vectordb_test/
# Reports (generated output)
data/reports/
# Keep data/.gitkeep so the data/ directory is tracked

# ─── Python ───────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── OS & Editor ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
# IDE directories — never commit these
.idea/
.kiro/
.vscode/settings.json
.vscode/launch.json
# Keep .vscode/extensions.json (useful for team)

# ─── Logs ─────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.pem
.vercel
/scratch/

# ─── SWC cache ────────────────────────────────────────────────────────────────
.swc/
